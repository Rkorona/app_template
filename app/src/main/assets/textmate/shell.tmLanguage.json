{
  "name": "Shell Script",
  "scopeName": "source.shell",
  "fileTypes": ["sh", "bash", "zsh"],
  "patterns": [
    {"include": "#shebang"},
    {"include": "#comment"},
    {"include": "#double_string"},
    {"include": "#single_string"},
    {"include": "#keywords"},
    {"include": "#variable_brace"},
    {"include": "#variable"},
    {"include": "#variable_positional"},
    {"include": "#command_substitution"},
    {"include": "#numbers"},
    {"include": "#function_definition"}
  ],
  "repository": {
    "shebang": {
      "name": "comment.line.shebang.shell",
      "match": "^#!.*$"
    },
    "comment": {
      "name": "comment.line.number-sign.shell",
      "match": "(?<!\\$)#.*$"
    },
    "double_string": {
      "name": "string.quoted.double.shell",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {"name": "constant.character.escape.shell", "match": "\\\\."},
        {"name": "variable.other.shell", "match": "\\$[A-Za-z_][A-Za-z0-9_]*"},
        {"name": "variable.other.shell", "match": "\\$\\{[^}]+\\}"},
        {"name": "variable.other.positional.shell", "match": "\\$[0-9@*#?$!-]"}
      ]
    },
    "single_string": {
      "name": "string.quoted.single.shell",
      "begin": "'",
      "end": "'"
    },
    "keywords": {
      "name": "keyword.control.shell",
      "match": "\\b(if|then|else|elif|fi|for|do|done|while|until|case|esac|in|select|function|return|break|continue|exit|shift|trap|eval|exec|export|local|readonly|declare|typeset|unset|source|alias|unalias|true|false|echo|printf|read|test|set|unset)\\b"
    },
    "variable_brace": {
      "name": "variable.other.shell",
      "match": "\\$\\{[^}]+\\}"
    },
    "variable": {
      "name": "variable.other.shell",
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
    },
    "variable_positional": {
      "name": "variable.other.positional.shell",
      "match": "\\$[0-9@*#?$!]"
    },
    "command_substitution": {
      "name": "meta.command-substitution.shell",
      "begin": "\\$\\(",
      "end": "\\)",
      "patterns": [
        {"include": "#keywords"},
        {"include": "#variable"},
        {"include": "#double_string"},
        {"include": "#single_string"}
      ]
    },
    "numbers": {
      "name": "constant.numeric.shell",
      "match": "(?<![A-Za-z_])\\b[0-9]+\\b"
    },
    "function_definition": {
      "name": "entity.name.function.shell",
      "match": "(?:^|;|\\s)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\(\\s*\\))"
    }
  }
}
