{
  "name": "ScriptHub Dark",
  "settings": [
    {
      "settings": {
        "background": "#1A1B26",
        "foreground": "#C0CAF5",
        "caret": "#C0CAF5",
        "lineHighlight": "#282A3A",
        "selection": "#364A82",
        "invisibles": "#3B4261"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": {
        "foreground": "#565F89",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Punctuation",
      "scope": "punctuation.definition.comment",
      "settings": {
        "foreground": "#565F89"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "String Escape",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Built-in Constant",
      "scope": "constant.language",
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Keyword Control",
      "scope": "keyword.control",
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Keyword Declaration",
      "scope": "keyword.declaration",
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Keyword Other",
      "scope": "keyword.other",
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Function Name",
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#7DCFFF"
      }
    },
    {
      "name": "Class Name",
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#2AC3DE"
      }
    },
    {
      "name": "Type Name",
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#2AC3DE"
      }
    },
    {
      "name": "Decorator",
      "scope": "entity.name.function.decorator",
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "name": "Variable",
      "scope": "variable.other",
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "name": "Shell Variable",
      "scope": "variable.other.shell",
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "name": "Positional Variable",
      "scope": "variable.other.positional.shell",
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Support Function",
      "scope": "support.function",
      "settings": {
        "foreground": "#7DCFFF"
      }
    },
    {
      "name": "Support Class",
      "scope": "support.class",
      "settings": {
        "foreground": "#2AC3DE"
      }
    },
    {
      "name": "Meta Template Expression",
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "name": "Shebang",
      "scope": "comment.line.shebang",
      "settings": {
        "foreground": "#E0AF68",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#F7768E"
      }
    }
  ]
}
