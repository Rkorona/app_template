{
  "name": "ScriptHub Light",
  "settings": [
    {
      "settings": {
        "background": "#F8F9FA",
        "foreground": "#383A42",
        "caret": "#383A42",
        "lineHighlight": "#EAEAEA",
        "selection": "#C8D3F5",
        "invisibles": "#CBCDD4"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": {
        "foreground": "#A0A1A7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Punctuation",
      "scope": "punctuation.definition.comment",
      "settings": {
        "foreground": "#A0A1A7"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#50A14F"
      }
    },
    {
      "name": "String Escape",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#A626A4"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#C18401"
      }
    },
    {
      "name": "Built-in Constant",
      "scope": "constant.language",
      "settings": {
        "foreground": "#C18401"
      }
    },
    {
      "name": "Keyword Control",
      "scope": "keyword.control",
      "settings": {
        "foreground": "#A626A4"
      }
    },
    {
      "name": "Keyword Declaration",
      "scope": "keyword.declaration",
      "settings": {
        "foreground": "#A626A4"
      }
    },
    {
      "name": "Keyword Other",
      "scope": "keyword.other",
      "settings": {
        "foreground": "#A626A4"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#0184BC"
      }
    },
    {
      "name": "Function Name",
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#4078F2"
      }
    },
    {
      "name": "Class Name",
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#C18401"
      }
    },
    {
      "name": "Type Name",
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#C18401"
      }
    },
    {
      "name": "Decorator",
      "scope": "entity.name.function.decorator",
      "settings": {
        "foreground": "#4078F2"
      }
    },
    {
      "name": "Variable",
      "scope": "variable.other",
      "settings": {
        "foreground": "#E45649"
      }
    },
    {
      "name": "Shell Variable",
      "scope": "variable.other.shell",
      "settings": {
        "foreground": "#E45649"
      }
    },
    {
      "name": "Support Function",
      "scope": "support.function",
      "settings": {
        "foreground": "#4078F2"
      }
    },
    {
      "name": "Support Class",
      "scope": "support.class",
      "settings": {
        "foreground": "#C18401"
      }
    },
    {
      "name": "Shebang",
      "scope": "comment.line.shebang",
      "settings": {
        "foreground": "#C18401",
        "fontStyle": "bold"
      }
    }
  ]
}
