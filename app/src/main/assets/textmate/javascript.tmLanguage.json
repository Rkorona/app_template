{
  "name": "JavaScript",
  "scopeName": "source.js",
  "fileTypes": ["js", "mjs", "cjs", "jsx"],
  "patterns": [
    {"include": "#block_comment"},
    {"include": "#line_comment"},
    {"include": "#template_string"},
    {"include": "#double_string"},
    {"include": "#single_string"},
    {"include": "#keywords_control"},
    {"include": "#keywords_declaration"},
    {"include": "#constants"},
    {"include": "#numbers"},
    {"include": "#class_definition"},
    {"include": "#function_definition"},
    {"include": "#function_call"}
  ],
  "repository": {
    "block_comment": {
      "name": "comment.block.js",
      "begin": "/\\*",
      "beginCaptures": {"0": {"name": "punctuation.definition.comment.js"}},
      "end": "\\*/",
      "endCaptures": {"0": {"name": "punctuation.definition.comment.js"}}
    },
    "line_comment": {
      "name": "comment.line.double-slash.js",
      "match": "//.*$"
    },
    "template_string": {
      "name": "string.template.js",
      "begin": "`",
      "end": "`",
      "patterns": [
        {"name": "constant.character.escape.js", "match": "\\\\."},
        {
          "name": "meta.template.expression.js",
          "begin": "\\$\\{",
          "beginCaptures": {"0": {"name": "keyword.operator.js"}},
          "end": "\\}",
          "endCaptures": {"0": {"name": "keyword.operator.js"}},
          "patterns": [
            {"include": "#keywords_control"},
            {"include": "#numbers"},
            {"include": "#constants"}
          ]
        }
      ]
    },
    "double_string": {
      "name": "string.quoted.double.js",
      "begin": "\"",
      "end": "\"",
      "patterns": [{"name": "constant.character.escape.js", "match": "\\\\."}]
    },
    "single_string": {
      "name": "string.quoted.single.js",
      "begin": "'",
      "end": "'",
      "patterns": [{"name": "constant.character.escape.js", "match": "\\\\."}]
    },
    "keywords_control": {
      "name": "keyword.control.js",
      "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|throw|try|catch|finally|of|in|instanceof|typeof|void|delete|yield|await|debugger|new)\\b"
    },
    "keywords_declaration": {
      "name": "keyword.declaration.js",
      "match": "\\b(var|let|const|function|class|import|export|from|as|async|extends|super|static|get|set|require|module)\\b"
    },
    "constants": {
      "name": "constant.language.js",
      "match": "\\b(true|false|null|undefined|NaN|Infinity|this|arguments|globalThis|console|Promise|Array|Object|String|Number|Boolean|Date|RegExp|Error|Math|JSON|Map|Set|Symbol|WeakMap|WeakSet|Proxy|Reflect|process|Buffer|__dirname|__filename)\\b"
    },
    "numbers": {
      "name": "constant.numeric.js",
      "match": "\\b(0[xX][0-9a-fA-F_]+[nN]?|0[bB][01_]+[nN]?|0[oO][0-7_]+[nN]?|(?:[0-9][0-9_]*\\.?[0-9_]*|\\.?[0-9][0-9_]*)(?:[eE][+-]?[0-9_]+)?[nN]?)\\b"
    },
    "class_definition": {
      "name": "entity.name.class.js",
      "match": "(?<=\\bclass\\s+)([A-Za-z_$][A-Za-z0-9_$]*)"
    },
    "function_definition": {
      "name": "entity.name.function.js",
      "match": "(?<=\\bfunction\\s*)([A-Za-z_$][A-Za-z0-9_$]*)(?=\\s*\\()"
    },
    "function_call": {
      "name": "entity.name.function.js",
      "match": "([A-Za-z_$][A-Za-z0-9_$]*)(?=\\s*\\()"
    }
  }
}
