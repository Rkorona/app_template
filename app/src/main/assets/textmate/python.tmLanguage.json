{
  "name": "Python",
  "scopeName": "source.python",
  "fileTypes": ["py", "pyw"],
  "patterns": [
    {"include": "#triple_double_string"},
    {"include": "#triple_single_string"},
    {"include": "#comment"},
    {"include": "#double_string"},
    {"include": "#single_string"},
    {"include": "#keywords"},
    {"include": "#constants"},
    {"include": "#numbers"},
    {"include": "#decorator"},
    {"include": "#function_definition"},
    {"include": "#class_definition"},
    {"include": "#builtin_functions"},
    {"include": "#function_call"}
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.python",
      "match": "#.*$"
    },
    "triple_double_string": {
      "name": "string.quoted.triple.double.python",
      "begin": "\"\"\"",
      "beginCaptures": {"0": {"name": "punctuation.definition.string.begin.python"}},
      "end": "\"\"\"",
      "endCaptures": {"0": {"name": "punctuation.definition.string.end.python"}},
      "patterns": [{"name": "constant.character.escape.python", "match": "\\\\."}]
    },
    "triple_single_string": {
      "name": "string.quoted.triple.single.python",
      "begin": "'''",
      "beginCaptures": {"0": {"name": "punctuation.definition.string.begin.python"}},
      "end": "'''",
      "endCaptures": {"0": {"name": "punctuation.definition.string.end.python"}},
      "patterns": [{"name": "constant.character.escape.python", "match": "\\\\."}]
    },
    "double_string": {
      "name": "string.quoted.double.python",
      "begin": "\"",
      "end": "\"",
      "patterns": [{"name": "constant.character.escape.python", "match": "\\\\."}]
    },
    "single_string": {
      "name": "string.quoted.single.python",
      "begin": "'",
      "end": "'",
      "patterns": [{"name": "constant.character.escape.python", "match": "\\\\."}]
    },
    "keywords": {
      "name": "keyword.control.python",
      "match": "\\b(if|elif|else|for|while|break|continue|return|pass|raise|try|except|finally|with|as|import|from|del|global|nonlocal|lambda|yield|async|await|and|or|not|in|is)\\b"
    },
    "constants": {
      "name": "constant.language.python",
      "match": "\\b(True|False|None|self|cls|__init__|__name__|__main__|__all__|__file__|__doc__)\\b"
    },
    "numbers": {
      "name": "constant.numeric.python",
      "match": "\\b(0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|[0-9][0-9_]*\\.?[0-9_]*(?:[eE][+-]?[0-9_]+)?[jJ]?|\\.[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)?[jJ]?)\\b"
    },
    "decorator": {
      "name": "entity.name.function.decorator.python",
      "match": "@[A-Za-z_][A-Za-z0-9_.]*"
    },
    "function_definition": {
      "match": "(?<=\\bdef\\s)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": {"name": "entity.name.function.python"}
      }
    },
    "class_definition": {
      "match": "(?<=\\bclass\\s)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*[:(])",
      "captures": {
        "1": {"name": "entity.name.class.python"}
      }
    },
    "builtin_functions": {
      "name": "support.function.builtin.python",
      "match": "\\b(print|len|range|type|str|int|float|list|dict|set|tuple|bool|bytes|open|input|super|isinstance|issubclass|hasattr|getattr|setattr|delattr|callable|iter|next|enumerate|zip|map|filter|sorted|reversed|any|all|min|max|sum|abs|round|id|hash|repr|format|vars|dir|help)\\b"
    },
    "function_call": {
      "name": "entity.name.function.python",
      "match": "([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()"
    }
  }
}
